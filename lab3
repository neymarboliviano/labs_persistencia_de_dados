const sqlite3 = require("sqlite3").verbose();

/*
  Este arquivo faz a conexão entre o
  Node.js e o banco de dados SQLite.
*/

const db = new sqlite3.Database("banco.db");

module.exports = db;




const express = require("express");
const db = require("./database");

const app = express();

// Adicionar produto
app.get("/adicionar/:nome", (req, res) => {
  const nome = req.params.nome;

  db.run(
    "INSERT INTO produtos (nome) VALUES (?)",
    [nome],
    (erro) => {
      if (erro) {
        return res.send("Erro ao cadastrar produto.");
      }

      res.send("Produto cadastrado com sucesso!");
    }
  );
});

// Listar todos os produtos
app.get("/produtos", (req, res) => {
  db.all(
    "SELECT * FROM produtos",
    [],
    (erro, rows) => {
      if (erro) {
        return res.send("Erro ao consultar produtos.");
      }

      res.json(rows);
    }
  );
});

// Buscar produto pelo ID
app.get("/produto/:id", (req, res) => {
  const id = req.params.id;

  db.get(
    "SELECT * FROM produtos WHERE id = ?",
    [id],
    (erro, row) => {
      if (erro) {
        return res.send("Erro na busca.");
      }

      if (!row) {
        return res.send("Produto não encontrado.");
      }

      res.json(row);
    }
  );
});

/*
  o node recebe as ações do usuário
  e envia comandos para o banco de dados.

  O INSERT adiciona novos produtos.

  O SELECT consulta os produtos cadastrados.

  os dados não são perdidos quando o servidor
  é reiniciado.
*/

app.listen(3000, () => {
  console.log("Servidor rodando na porta 3000");
});
